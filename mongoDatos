import serial
from pymongo import MongoClient
from urllib.parse import quote_plus
from datetime import datetime
import pytz

# Zona horaria
timezone = pytz.timezone('America/Bogota')

# 🔌 Puerto serial COM5 (ajusta si es necesario)
puerto_serial = serial.Serial('COM5', 9600, timeout=1)
print("🟢 Esperando datos desde el Arduino (COM5)...")

# 🛡️ MongoDB Atlas URI
#usuario = quote_plus("karenjnps")
