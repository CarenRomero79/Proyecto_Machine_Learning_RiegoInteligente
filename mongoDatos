#cluster = "cluster0.dcf60ha.mongodb.net"
base_datos = "base_datos"

#uri = f"mongodb+srv://{usuario}:{clave}@{cluster}/{base_datos}?retryWrites=true&w=majority&appName=Cluster0"

# Conexión MongoDB
